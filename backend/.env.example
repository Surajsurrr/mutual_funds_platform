# ─── App tier ────────────────────────────────────────────────────────────────
# read | write | worker | all (dev default: all)
API_ROLE=all
WRITE_PORT=5000
READ_PORT=5001

# ─── Layer 4: primary via PgBouncer in production ────────────────────────────
# dev default (embedded postgres): postgresql://postgres:postgres@127.0.0.1:5433/fundflow
# docker stack (via pgbouncer):    postgresql://fundflow:fundflow@localhost:6432/fundflow
DATABASE_URL=

# ─── Layer 3: comma-separated read replicas (empty = reads hit primary) ──────
# docker stack: postgresql://fundflow:fundflow@localhost:5442/fundflow
REPLICA_URLS=

# ─── Layers 2 + 5: Redis cache + streams (empty = in-process fallbacks) ──────
# docker stack: redis://localhost:6379
REDIS_URL=

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_EXPIRY=12h

# ─── Order intake: true = zero DB work on request path (NFO burst mode) ──────
ORDER_THIN_INTAKE=false

# ─── Workers / retries (PDF: 2s → 4s → 8s + jitter) ──────────────────────────
ORDER_BATCH_SIZE=100
ORDER_BATCH_WAIT_MS=500
RETRY_MAX_ATTEMPTS=3
RETRY_BASE_DELAY_MS=2000
BANK_FAILURE_RATE=0.05
BANK_LATENCY_MS=300

# ─── Rate limits (per user/IP per minute) ────────────────────────────────────
RATE_READ_PER_MIN=300
RATE_WRITE_PER_MIN=60
RATE_ORDER_PER_MIN=20
